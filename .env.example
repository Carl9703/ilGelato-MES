# SQLite database path (relative to project root / CWD)
# Local dev — db file at prisma/dev.db:
DATABASE_URL="file:./prisma/dev.db"

# Gemini AI API key (optional — only needed for AI features)
GEMINI_API_KEY=""

# Express server port
# Local dev: 3000  |  Docker: 5000 (set in docker-compose.yml)
PORT=3000

# Token chroniący endpoint /api/reset (DELETE wszystkich danych)
# Bez tej zmiennej endpoint jest zablokowany (503).
# Wygeneruj losowy string, np.: openssl rand -hex 32
RESET_SECRET=""
